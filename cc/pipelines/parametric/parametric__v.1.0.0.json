        "jsonBody": "={\n  \"instances\": [\n    {\n      \"prompt\": \"{{ $('Parametric Trigger').item.json.body.prompt }}\"\n    }\n  ],\n  \"parameters\": {\n    \"aspectRatio\": \"9:16\",\n    \"guidanceScale\": 15,\n    \"outputOptions\": {\n      \"compressionQuality\": 80,\n      \"mimeType\": \"image/jpeg\"\n    },\n    \"safetySettings\": {\n      \"personGeneration\": \"allow_adult\",\n      \"safetyFilterLevel\": \"block_only_high\"\n    },\n    \"sampleCount\": 2\n  }\n}",
