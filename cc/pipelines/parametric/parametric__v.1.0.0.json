        "googleOAuth2Api": {
          "id": "GG4l16ZGtrJkRBVQ",
          "name": "CC : Google OAuth2"
        }
      },
      "notes": "POST  |  Generate Image"
    },
    {
      "parameters": {
        "jsCode": "// Function Node code for n8n\n\n// Input may be:\n// - an array of items (each item containing predictions)\n// - a single item object containing a predictions array\nconst inputItem = $input.item.json;\n\nlet predictionsList = null;\n\n// Determine the structure\nif (Array.isArray(inputItem)) {\n  // Input is an array of items – use the whole array\n  predictionsList = inputItem;\n} else if (inputItem && Array.isArray(inputItem.predictions)) {\n  // Input is a single object with a predictions array\n  predictionsList = inputItem.predictions;\n} else {\n  // If it's a single object but doesn't have predictions, maybe it's the actual prediction?\n  // In the given structure, the object has \"predictions\", so we'll stick to that.\n  throw new Error('Input must be an array or an object with a \"predictions\" array');\n}\n\nif (predictionsList.length === 0) {\n  throw new Error('No predictions found');\n}\n\nconst outputItems = [];\n\n// predictionsList is an array of prediction objects\npredictionsList.forEach((prediction, index) => {\n  const base64Data = prediction.bytesBase64Encoded;\n  if (!base64Data) {\n    // Skip if missing base64 data\n    return;\n  }\n\n  // Convert base64 to binary Buffer\n  const imageBuffer = Buffer.from(base64Data, 'base64');\n\n  // Create a filename – you can customize the naming logic\n  const filename = `imagen_image_${index}.jpg`;\n\n  // Build the item that n8n expects for binary data\n  outputItems.push({\n    json: {\n      // Include any metadata you want to keep (e.g., prompt)\n      prompt: prediction.prompt,\n      index: index,\n      mimeType: prediction.mimeType || 'image/jpeg',\n    },\n    binary: {\n      data: {\n        data: imageBuffer,\n        fileName: filename,\n        mimeType: prediction.mimeType || 'image/jpeg',\n      },\n    },\n  });\n});\n\nif (outputItems.length === 0) {\n  throw new Error('No valid base64 images found');\n}\n\nreturn outputItems;"
      },
